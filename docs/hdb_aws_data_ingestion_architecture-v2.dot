
digraph G {
graph [rankdir=TB,bgcolor="white",pad="0.3",nodesep="0.35",ranksep="0.65",
fontname="Arial",labelloc="t",label="AWS Batch Data Ingestion Architecture",
fontsize="20",splines=ortho];
node [shape=box,style="rounded,filled",fillcolor="white",color="#94A3B8",
fontname="Arial",fontsize="11",margin="0.12"];
edge [color="#475569",penwidth="1.4,arrowsize=0.8",fontname="Arial",fontsize="9"];

data_gov [label="data.gov.sg\nPublic HTTPS endpoint",fillcolor="#FFF7ED",color="#F97316"];

subgraph cluster_aws {
label="HDB AWS Account"; color="#CBD5E1"; style="rounded"; penwidth=1.3;

eventbridge [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD><IMG SRC="/mnt/data/part2_architecture/icons/eventbridge.png"/></TD></TR><TR><TD><B>EventBridge Scheduler</B></TD></TR><TR><TD><FONT POINT-SIZE="9" COLOR="#475569">Scheduled batch trigger</FONT></TD></TR>
</TABLE>>];
sfn [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD><IMG SRC="/mnt/data/part2_architecture/icons/stepfunctions.png"/></TD></TR><TR><TD><B>AWS Step Functions</B></TD></TR><TR><TD><FONT POINT-SIZE="9" COLOR="#475569">Orchestration, retry and failure handling</FONT></TD></TR>
</TABLE>>];

subgraph cluster_vpc {
label="HDB VPC"; color="#86EFAC"; style="rounded"; penwidth=1.5;

subgraph cluster_private {
label="Private Application Subnets (Multi-AZ)"; color="#BFDBFE"; style="rounded,dashed";
fargate [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD><IMG SRC="/mnt/data/part2_architecture/icons/fargate.png"/></TD></TR><TR><TD><B>ECS Fargate Downloader</B></TD></TR><TR><TD><FONT POINT-SIZE="9" COLOR="#475569">No public IP; streaming download</FONT></TD></TR>
</TABLE>>];
}

subgraph cluster_egress {
label="Public Egress Subnet"; color="#FED7AA"; style="rounded,dashed";
nat [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD><IMG SRC="/mnt/data/part2_architecture/icons/nat.png"/></TD></TR><TR><TD><B>NAT Gateway</B></TD></TR><TR><TD><FONT POINT-SIZE="9" COLOR="#475569">Controlled outbound HTTPS</FONT></TD></TR>
</TABLE>>];
igw [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD><IMG SRC="/mnt/data/part2_architecture/icons/igw.png"/></TD></TR><TR><TD><B>Internet Gateway</B></TD></TR><TR><TD><FONT POINT-SIZE="9" COLOR="#475569">Public egress only</FONT></TD></TR>
</TABLE>>];
}

s3ep [label="S3 Gateway VPC Endpoint\nPrivate S3 traffic",fillcolor="#ECFDF5",color="#10B981"];
}

raw [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD><IMG SRC="/mnt/data/part2_architecture/icons/s3.png"/></TD></TR><TR><TD><B>Amazon S3 — Raw Zone</B></TD></TR><TR><TD><FONT POINT-SIZE="9" COLOR="#475569">Immutable, versioned, SSE-KMS</FONT></TD></TR>
</TABLE>>];
glue [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD><IMG SRC="/mnt/data/part2_architecture/icons/glue.png"/></TD></TR><TR><TD><B>AWS Glue ETL</B></TD></TR><TR><TD><FONT POINT-SIZE="9" COLOR="#475569">Run Part 1 validation and transformation</FONT></TD></TR>
</TABLE>>];
processed [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD><IMG SRC="/mnt/data/part2_architecture/icons/s3.png"/></TD></TR><TR><TD><B>Amazon S3 — Processed Zones</B></TD></TR><TR><TD><FONT POINT-SIZE="9" COLOR="#475569">cleaned / transformed / failed / hashed\nPartitioned Parquet</FONT></TD></TR>
</TABLE>>];
catalog [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD><IMG SRC="/mnt/data/part2_architecture/icons/glue.png"/></TD></TR><TR><TD><B>AWS Glue Data Catalog</B></TD></TR><TR><TD><FONT POINT-SIZE="9" COLOR="#475569">Table and partition metadata</FONT></TD></TR>
</TABLE>>];
cw [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD><IMG SRC="/mnt/data/part2_architecture/icons/cloudwatch.png"/></TD></TR><TR><TD><B>Amazon CloudWatch</B></TD></TR><TR><TD><FONT POINT-SIZE="9" COLOR="#475569">Logs, metrics and alarms</FONT></TD></TR>
</TABLE>>];
sns [label=<
<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
<TR><TD><IMG SRC="/mnt/data/part2_architecture/icons/sns.png"/></TD></TR><TR><TD><B>Amazon SNS</B></TD></TR><TR><TD><FONT POINT-SIZE="9" COLOR="#475569">Failure notification</FONT></TD></TR>
</TABLE>>];
}

eventbridge -> sfn [label="start"];
sfn -> fargate [label="run task"];
fargate -> nat [label="HTTPS 443"];
nat -> igw;
igw -> data_gov [dir=both,label="download"];
fargate -> s3ep [label="multipart upload"];
s3ep -> raw;
sfn -> glue [label="start after upload"];
raw -> glue [label="job input"];
glue -> processed [label="write output"];
glue -> catalog [label="update metadata"];
sfn -> cw [style=dashed];
fargate -> cw [style=dashed];
glue -> cw [style=dashed];
cw -> sns [style=dashed,label="alarm"];
}
